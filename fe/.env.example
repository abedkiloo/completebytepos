# Copy to fe/.env.local (gitignored) or set in workspace root .env for Docker Compose.
#
# Create React App only exposes variables prefixed with REACT_APP_

# --- Local machine (npm start on laptop) ---
REACT_APP_API_URL=http://localhost:8000/api

# --- Server / Docker dev (browser opens http://YOUR_IP:3000) ---
# Leave empty or comment out — app auto-uses http://YOUR_IP:8000/api
# REACT_APP_API_URL=

# Optional if backend is not on 8000
# REACT_APP_API_PORT=8000

# --- Production Docker build (nginx proxies /api) ---
# Set in workspace root .env before: ./run_docker.sh --prod --rebuild
# REACT_APP_API_URL=/api
