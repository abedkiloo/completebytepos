# Copy to fe/.env (or fe/.env.local) and set for your environment.
# Docker Compose can also set REACT_APP_API_URL in workspace root .env.

# Local npm start / laptop
REACT_APP_API_URL=http://localhost:8000/api

# Remote dev server (UI on :3000, API on :8000)
# REACT_APP_API_URL=http://YOUR_SERVER_IP:8000/api

# Production build (nginx on port 80)
# REACT_APP_API_URL=/api
