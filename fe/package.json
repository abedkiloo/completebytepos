{
  "name": "fe",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.11.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:unit": "react-scripts test --watchAll=false --testPathPattern=\"src/(utils|config|hooks)/\"",
    "test:coverage": "react-scripts test --watchAll=false --coverage --testPathPattern=\"src/(utils|config|hooks)/\"",
    "test:coverage:all": "react-scripts test --watchAll=false --coverage --testPathPattern=\"src/(utils|config|hooks)/|Display\\.test|moduleSettingsCache|FeatureFlag|sellingPrice\" --coverageThreshold='{}'",
    "test:flags": "react-scripts test --watchAll=false --testPathPattern=\"Display|moduleSettingsCache|FeatureFlag|useModuleSettings|productDisplay|sellingPrice|sessionIdle\"",
    "test:e2e": "playwright test -c e2e/playwright.config.js",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:smoke": "playwright test -c e2e/playwright.config.js specs/smoke-routes.spec.js specs/pos-smoke.spec.js",
    "test:e2e:settings": "playwright test -c e2e/playwright.config.js specs/module-settings.spec.js specs/high-impact-settings.spec.js specs/products.spec.js",
    "test:e2e:persona": "playwright test -c e2e/playwright.config.js specs/persona-access.spec.js",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/config/apiBaseUrl.js",
      "src/utils/formValidation.js",
      "src/utils/userFormPayload.js",
      "src/utils/categoryTree.js",
      "src/utils/walkInCustomer.js",
      "src/utils/paymentMethods.js",
      "src/utils/modulePresets.js",
      "src/utils/moduleDomains.js",
      "src/utils/apiErrors.js",
      "src/utils/formatters.js",
      "src/utils/mediaUrl.js",
      "src/utils/productStock.js",
      "src/utils/productPricing.js",
      "src/utils/setupStatus.js",
      "src/utils/storeSettingsCache.js",
      "src/hooks/useStoreSettings.js",
      "src/hooks/useProductVariantsEnabled.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 82,
        "functions": 92,
        "lines": 95,
        "statements": 95
      },
      "./src/config/apiBaseUrl.js": {
        "branches": 85,
        "functions": 95,
        "lines": 95,
        "statements": 95
      },
      "./src/utils/formValidation.js": {
        "branches": 88,
        "functions": 95,
        "lines": 95,
        "statements": 90
      },
      "./src/utils/userFormPayload.js": {
        "branches": 68,
        "functions": 95,
        "lines": 95,
        "statements": 95
      },
      "./src/utils/categoryTree.js": {
        "branches": 75,
        "functions": 85,
        "lines": 95,
        "statements": 93
      }
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
