# Copy to .env in workspace root (beside be/ and fe/):
#   cp .env.example .env
#
# Setup guide (Docker, VPS, REACT_APP_API_URL, tenant/branch):
#   docs/SETUP.md

# =============================================================================
# Django core
# =============================================================================
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_SETTINGS_MODULE=config.settings

# Comma-separated hosts. Docker internal names (backend, frontend) are added automatically.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
# Your server public IP or domain — also used for CORS/CSRF when set:
PUBLIC_HOST=YOUR_SERVER_IP

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=completebytepos
POSTGRES_USER=completebytepos
POSTGRES_PASSWORD=completebytepos
POSTGRES_PORT=5432

DB_HOST=db
DB_PORT=5432
DB_NAME=completebytepos
DB_USER=completebytepos
DB_PASSWORD=completebytepos
DB_CONN_MAX_AGE=60

# Optional: postgresql://user:pass@host:5432/dbname
# DATABASE_URL=

# Legacy SQLite (not recommended)
# USE_SQLITE=true
# DB_PATH=./be/db.sqlite3

# =============================================================================
# Locale
# =============================================================================
LANGUAGE_CODE=en-us
TIME_ZONE=Africa/Nairobi

# =============================================================================
# Static / media
# =============================================================================
STATIC_URL=/static/
STATIC_ROOT=/app/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/app/media
# Serve uploads from Django when DEBUG=False (default: true). Nginx also proxies /media/ → backend.
SERVE_MEDIA=true
# Optional; defaults to http://PUBLIC_HOST:FRONTEND_PORT in production (DEBUG=False).
# In local DEBUG, the API returns relative /media/ paths; CRA proxies /media → backend.
# MEDIA_PUBLIC_BASE_URL=http://YOUR_SERVER_IP:3000

# =============================================================================
# JWT
# =============================================================================
# Access token lifetime (minutes). Frontend idle logout uses the same 5-minute window.
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True
# JWT_SIGNING_KEY=   # defaults to SECRET_KEY

# =============================================================================
# API
# =============================================================================
API_PAGE_SIZE=20
THROTTLE_LOGIN_RATE=10/min

# =============================================================================
# CORS / CSRF (comma-separated URLs)
# =============================================================================
# In DEBUG=True, CORS_ALLOW_ALL_ORIGINS defaults to True unless you set it False
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOW_CREDENTIALS=True

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://frontend:80

CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# Extra CORS headers (comma-separated)
CORS_EXTRA_ALLOWED_HEADERS=x-branch-id,X-Branch-ID,ngrok-skip-browser-warning

# Regex patterns for tunnels (comma-separated)
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.ngrok-free\.app$,^https://.*\.ngrok\.io$,^https://.*\.ngrok\.app$

CORS_PREFLIGHT_MAX_AGE=86400

# =============================================================================
# Cookies / HTTPS (production behind TLS)
# =============================================================================
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
# Set True when behind nginx/traefik terminating TLS
USE_SECURE_PROXY_SSL_HEADER=False

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# =============================================================================
# Frontend (Docker / CRA build)
# =============================================================================
# Dev Docker (UI :3000) — required when not on localhost:
# REACT_APP_API_URL=http://YOUR_SERVER_IP:8000/api
# Prod Docker (--prod, nginx :80):
# REACT_APP_API_URL=/api
FRONTEND_PORT=3000
