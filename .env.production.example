# Production template — copy to .env
#   cp .env.production.example .env

DEBUG=False
SECRET_KEY=replace-with-long-random-secret

ALLOWED_HOSTS=your-domain.com,www.your-domain.com
PUBLIC_HOST=216.158.230.163

POSTGRES_DB=completebytepos
POSTGRES_USER=completebytepos
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_PORT=5432

DB_HOST=db
DB_PORT=5432
DB_NAME=completebytepos
DB_USER=completebytepos
DB_PASSWORD=replace-with-strong-password

LANGUAGE_CODE=en-us
TIME_ZONE=Africa/Nairobi

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOWED_ORIGINS=https://your-domain.com,http://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,http://your-domain.com

CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=False
USE_SECURE_PROXY_SSL_HEADER=True

JWT_ACCESS_TOKEN_MINUTES=5
JWT_REFRESH_TOKEN_DAYS=7

REACT_APP_API_URL=/api
FRONTEND_PORT=3000

LOG_LEVEL=WARNING
